{
  "name": "highgrid",
  "version": "1.0.1",
  "description": "Production-ready data grid library in vanilla JavaScript",
  "main": "dist/highgrid.umd.cjs",
  "module": "dist/highgrid.js",
  "types": "./index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/highgrid.js",
      "require": "./dist/highgrid.umd.cjs",
      "default": "./dist/highgrid.js"
    },
    "./vue": {
      "types": "./dist/highgrid-vue.d.ts",
      "import": "./dist/highgrid-vue.js",
      "default": "./dist/highgrid-vue.js"
    },
    "./react": {
      "import": "./src/adapters/react/index.js",
      "default": "./src/adapters/react/index.js"
    },
    "./styles/grid.css": "./dist/assets/grid.css",
    "./styles/tokens.css": "./src/styles/tokens.css"
  },
  "scripts": {
    "dev": "vite examples",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.js",
    "build:vue": "vite build --config vite.vue.config.js",
    "build:all": "npm run build && npm run build:vue",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:ci": "npm test && npm run test:e2e && npm run build:all"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "echarts": "^6.1.0",
    "jsdom": "^26.1.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.4.0"
  },
  "keywords": [
    "datagrid",
    "table",
    "virtual-scroll",
    "enterprise"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheonghakim/high-grid.git"
  },
  "homepage": "https://cheonghakim.github.io/high-grid",
  "bugs": {
    "url": "https://github.com/cheonghakim/high-grid/issues"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
