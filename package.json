{
  "name": "zenith-grid",
  "version": "3.0.0",
  "description": "Production-ready data grid library in vanilla JavaScript",
  "main": "dist/zenith-grid.umd.cjs",
  "module": "dist/zenith-grid.js",
  "types": "./index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src/styles",
    "index.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/zenith-grid.js",
      "require": "./dist/zenith-grid.umd.cjs",
      "default": "./dist/zenith-grid.js"
    },
    "./vue": {
      "types": "./dist/zenith-grid-vue.d.ts",
      "import": "./dist/zenith-grid-vue.js",
      "default": "./dist/zenith-grid-vue.js"
    },
    "./vue2": {
      "types": "./dist/zenith-grid-vue2.d.ts",
      "import": "./dist/zenith-grid-vue2.js",
      "require": "./dist/zenith-grid-vue2.umd.cjs",
      "default": "./dist/zenith-grid-vue2.js"
    },
    "./react": {
      "types": "./dist/zenith-grid-react.d.ts",
      "import": "./dist/zenith-grid-react.js",
      "require": "./dist/zenith-grid-react.cjs",
      "default": "./dist/zenith-grid-react.js"
    },
    "./styles/grid.css": "./src/styles/grid.css",
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./src/styles/grid.css": "./src/styles/grid.css",
    "./src/styles/tokens.css": "./src/styles/tokens.css"
  },
  "scripts": {
    "dev": "vite examples",
    "dev:showcase": "vite --config vite.showcase.config.js",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.js",
    "build:showcase": "vite build --config vite.showcase.config.js",
    "build:vue": "node build-vue3.js",
    "build:vue2": "node build-vue2.js",
    "build:react": "node build-react.js",
    "build:all": "npm run build && npm run build:vue && npm run build:vue2 && npm run build:react",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:ci": "npm test && npm run test:e2e && npm run build:all",
    "prepublishOnly": "npm run build:all"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vue": "~2.7.10 || ^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "echarts": "^6.1.0",
    "jsdom": "^26.1.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.4.0"
  },
  "keywords": [
    "datagrid",
    "table",
    "virtual-scroll",
    "enterprise"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheonghakim/zenith-grid.git"
  },
  "homepage": "https://cheonghakim.github.io/zenith-grid",
  "bugs": {
    "url": "https://github.com/cheonghakim/zenith-grid/issues"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "hot-formula-parser": "^4.0.0"
  }
}
